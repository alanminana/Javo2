@model IEnumerable<javo2.ViewModels.Operaciones.Clientes.ClientesViewModel>

@{
    ViewBag.Title = "Clientes";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2>@ViewBag.Title</h2>

<div class="row mb-4">
    <div class="col-md-3">
        <input type="text" class="form-control" id="filterName" placeholder="Filtrar por nombre">
    </div>
    <div class="col-md-3">
        <button class="btn btn-primary" id="applyFilters">Aplicar Filtros</button>
    </div>
</div>

<table class="table">
    <thead>
        <tr>
            <th>ID</th>
            <th>Nombre</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody id="clientesTableBody">
        @foreach (var cliente in Model)
        {
            <tr>
                <td>@cliente.ClienteID</td>
                <td>@cliente.Nombre</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@cliente.ClienteID" class="btn btn-primary">Editar</a>
                    <a asp-action="Details" asp-route-id="@cliente.ClienteID" class="btn btn-info">Detalles</a>
                    <a asp-action="Delete" asp-route-id="@cliente.ClienteID" class="btn btn-danger">Eliminar</a>
                </td>
            </tr>
        }
    </tbody>
</table>

<a asp-action="Create" class="btn btn-success">Agregar Cliente</a>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#applyFilters').click(function () {
                var filterName = $('#filterName').val().toLowerCase();
                $('#clientesTableBody tr').filter(function () {
                    $(this).toggle($(this).text().toLowerCase().indexOf(filterName) > -1)
                });
            });
        });
    </script>
}
