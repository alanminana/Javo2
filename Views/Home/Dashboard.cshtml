@* Views/Home/Dashboard.cshtml *@
@{
    ViewBag.Title = "Dashboard";
}

<h1 class="mb-4">Dashboard</h1>

<!-- Tarjetas de Resumen -->
<div class="summary-cards">
    <div class="summary-card">
        <h5>Cantidad de Ventas</h5>
        <p>1,234</p>
    </div>
    <div class="summary-card">
        <h5>Ventas Pendientes</h5>
        <p>56</p>
    </div>
    <div class="summary-card">
        <h5>Pedidos a Proveedores Pendientes</h5>
        <p>12</p>
    </div>
</div>

<!-- Gráficos -->
<div class="row">
    <!-- Gráfico de Clientes -->
    <div class="col-lg-6 mb-4">
        <div class="card p-3">
            <h5 class="card-title">Clientes</h5>
            <div class="chart-container">
                <canvas id="clientesChart"></canvas>
            </div>
        </div>
    </div>
    <!-- Gráfico de Ventas -->
    <div class="col-lg-6 mb-4">
        <div class="card p-3">
            <h5 class="card-title">Ventas</h5>
            <div class="chart-container">
                <canvas id="ventasChart"></canvas>
            </div>
        </div>
    </div>
</div>
<div class="row">
    <!-- Gráfico de Productos -->
    <div class="col-lg-6 mb-4">
        <div class="card p-3">
            <h5 class="card-title">Productos</h5>
            <div class="chart-container">
                <canvas id="productosChart"></canvas>
            </div>
        </div>
    </div>
    <!-- Gráfico de Proveedores -->
    <div class="col-lg-6 mb-4">
        <div class="card p-3">
            <h5 class="card-title">Proveedores</h5>
            <div class="chart-container">
                <canvas id="proveedoresChart"></canvas>
            </div>
        </div>
    </div>
</div>

<!-- Scripts para los Gráficos -->
@section Scripts {
    <script>
        // Asegúrate de que el DOM esté completamente cargado antes de inicializar los gráficos
        document.addEventListener('DOMContentLoaded', function () {
            // Gráfico de Clientes
            const ctxClientes = document.getElementById('clientesChart').getContext('2d');
            const clientesChart = new Chart(ctxClientes, {
                type: 'bar',
                data: {
                    labels: ['Enero', 'Febrero', 'Marzo', 'Abril', 'Mayo', 'Junio'],
                    datasets: [{
                        label: 'Nuevos Clientes',
                        data: [50, 60, 70, 80, 90, 100],
                        backgroundColor: 'rgba(255, 87, 34, 0.8)',
                        borderColor: 'rgba(255, 87, 34, 1)',
                        borderWidth: 1
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            labels: {
                                color: '#f0f0f0'
                            }
                        }
                    },
                    scales: {
                        x: {
                            ticks: {
                                color: '#f0f0f0'
                            },
                            grid: {
                                color: 'rgba(240, 240, 240, 0.1)'
                            }
                        },
                        y: {
                            ticks: {
                                color: '#f0f0f0'
                            },
                            grid: {
                                color: 'rgba(240, 240, 240, 0.1)'
                            }
                        }
                    }
                }
            });

            // Gráfico de Ventas
            const ctxVentas = document.getElementById('ventasChart').getContext('2d');
            const ventasChart = new Chart(ctxVentas, {
                type: 'line',
                data: {
                    labels: ['Enero', 'Febrero', 'Marzo', 'Abril', 'Mayo', 'Junio'],
                    datasets: [{
                        label: 'Ventas',
                        data: [2000, 3000, 4000, 3500, 5000, 6000],
                        backgroundColor: 'rgba(76, 175, 80, 0.4)',
                        borderColor: 'rgba(76, 175, 80, 1)',
                        fill: true,
                        tension: 0.4
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            labels: {
                                color: '#f0f0f0'
                            }
                        }
                    },
                    scales: {
                        x: {
                            ticks: {
                                color: '#f0f0f0'
                            },
                            grid: {
                                color: 'rgba(240, 240, 240, 0.1)'
                            }
                        },
                        y: {
                            ticks: {
                                color: '#f0f0f0'
                            },
                            grid: {
                                color: 'rgba(240, 240, 240, 0.1)'
                            }
                        }
                    }
                }
            });

            // Gráfico de Productos
            const ctxProductos = document.getElementById('productosChart').getContext('2d');
            const productosChart = new Chart(ctxProductos, {
                type: 'pie',
                data: {
                    labels: ['Electrónica', 'Ropa', 'Hogar', 'Juguetes'],
                    datasets: [{
                        label: 'Productos',
                        data: [40, 25, 20, 15],
                        backgroundColor: [
                            'rgba(33, 150, 243, 0.8)',
                            'rgba(255, 193, 7, 0.8)',
                            'rgba(156, 39, 176, 0.8)',
                            'rgba(255, 152, 0, 0.8)'
                        ],
                        borderColor: [
                            'rgba(33, 150, 243, 1)',
                            'rgba(255, 193, 7, 1)',
                            'rgba(156, 39, 176, 1)',
                            'rgba(255, 152, 0, 1)'
                        ],
                        borderWidth: 1
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            labels: {
                                color: '#f0f0f0'
                            }
                        }
                    }
                }
            });

            // Gráfico de Proveedores
            const ctxProveedores = document.getElementById('proveedoresChart').getContext('2d');
            const proveedoresChart = new Chart(ctxProveedores, {
                type: 'doughnut',
                data: {
                    labels: ['Local', 'Internacional'],
                    datasets: [{
                        label: 'Proveedores',
                        data: [70, 30],
                        backgroundColor: [
                            'rgba(0, 188, 212, 0.8)',
                            'rgba(233, 30, 99, 0.8)'
                        ],
                        borderColor: [
                            'rgba(0, 188, 212, 1)',
                            'rgba(233, 30, 99, 1)'
                        ],
                        borderWidth: 1
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            labels: {
                                color: '#f0f0f0'
                            }
                        }
                    }
                }
            });
        });
    </script>
}
