@using Javo2.ViewModels.Operaciones.Catalogo
@model RubroViewModel

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Eliminar Rubro";
}

<h2 class="mb-4">@ViewBag.Title</h2>

<div class="alert alert-danger">
    <h4 class="alert-heading">¿Está seguro que desea eliminar este rubro?</h4>
    <p>Esta acción no se puede deshacer.</p>
</div>

<div class="card p-4">
    <dl class="row">
        <dt class="col-sm-3">Nombre</dt>
        <dd class="col-sm-9">@Model.Nombre</dd>
    </dl>

    <form asp-action="DeleteRubro" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="btn btn-danger me-2">Eliminar</button>
        <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
    </form>
</div>
