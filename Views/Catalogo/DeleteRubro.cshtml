@using Javo2.ViewModels.Operaciones.Catalogo
@model RubroViewModel

@{
    ViewBag.Title = "Eliminar Rubro";
}

<h2>@ViewBag.Title</h2>

<h3>¿Está seguro que desea eliminar este rubro?</h3>
<div>
    <h4>@Model.Nombre</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            Nombre
        </dt>
        <dd class="col-sm-10">
            @Model.Nombre
        </dd>
    </dl>

    <form asp-action="DeleteRubro">
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="btn btn-danger">Eliminar</button>
        <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
    </form>
</div>
