@model Javo2.ViewModels.Operaciones.Productos.ProductosViewModel

@{
    ViewBag.Title = "Detalles del Producto";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2 class="mb-4">@ViewBag.Title</h2>

<div class="card p-4">
    <dl class="row">
        <dt class="col-sm-3">ID</dt>
        <dd class="col-sm-9">@Model.ProductoID</dd>

        <dt class="col-sm-3">Nombre</dt>
        <dd class="col-sm-9">@Model.Nombre</dd>

        <dt class="col-sm-3">Descripción</dt>
        <dd class="col-sm-9">@Model.Descripcion</dd>

        <dt class="col-sm-3">Precio Costo</dt>
        <dd class="col-sm-9">@Model.PCosto</dd>

        <dt class="col-sm-3">Precio Contado</dt>
        <dd class="col-sm-9">@Model.PContado</dd>

        <dt class="col-sm-3">Precio Lista</dt>
        <dd class="col-sm-9">@Model.PLista</dd>

        <dt class="col-sm-3">Porcentaje IVA</dt>
        <dd class="col-sm-9">@Model.PorcentajeIva</dd>
    </dl>
    <div class="mt-4">
        <a asp-action="Edit" asp-route-id="@Model.ProductoID" class="btn btn-primary me-2">
            <i class="bi bi-pencil-square"></i> Editar
        </a>
        <a asp-action="Index" class="btn btn-secondary">
            <i class="bi bi-arrow-left-circle"></i> Volver al listado
        </a>
    </div>
</div>
