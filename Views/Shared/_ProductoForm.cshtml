@model javo2.ViewModels.Operaciones.Productos.ProductosViewModel

<div class="container">
    <fieldset class="mb-4">
        <legend>Datos del Producto</legend>
        <div class="row g-3">
            <div class="col-md-6 form-group">
                <label asp-for="Nombre" class="control-label"></label>
                <input asp-for="Nombre" class="form-control" />
                <span asp-validation-for="Nombre" class="text-danger"></span>
            </div>
            <div class="col-md-6 form-group">
                <label asp-for="Descripcion" class="control-label"></label>
                <input asp-for="Descripcion" class="form-control" />
                <span asp-validation-for="Descripcion" class="text-danger"></span>
            </div>
        </div>
    </fieldset>

    <fieldset class="mb-4">
        <legend>Clasificación</legend>
        <div class="row g-3">
            <div class="col-md-6 form-group">
                <label asp-for="SelectedSubRubroId" class="form-label"></label>
                <select asp-for="SelectedSubRubroId" class="form-control" asp-items="Model.SubRubros">
                    <option value="">Seleccione un sub rubro</option>
                </select>
                <span asp-validation-for="SelectedSubRubroId" class="text-danger"></span>
            </div>
            <div class="col-md-6 form-group">
                <label asp-for="SelectedMarcaId" class="form-label"></label>
                <select asp-for="SelectedMarcaId" class="form-control" asp-items="Model.Marcas">
                    <option value="">Seleccione una Marca</option>
                </select>
                <span asp-validation-for="SelectedMarcaId" class="text-danger"></span>
            </div>
        </div>
    </fieldset>

    <fieldset class="mb-4">
        <legend>Precios</legend>
        <div class="row g-3">
            <div class="col-md-6 form-group">
                <label asp-for="PCosto" class="control-label"></label>
                <input asp-for="PCosto" class="form-control" />
                <span asp-validation-for="PCosto" class="text-danger"></span>
            </div>
            <div class="col-md-6 form-group">
                <label asp-for="PContado" class="control-label"></label>
                <input asp-for="PContado" class="form-control" />
                <span asp-validation-for="PContado" class="text-danger"></span>
            </div>
            <div class="col-md-6 form-group">
                <label asp-for="PLista" class="control-label"></label>
                <input asp-for="PLista" class="form-control" />
                <span asp-validation-for="PLista" class="text-danger"></span>
            </div>
            <div class="col-md-6 form-group">
                <label asp-for="PorcentajeIva" class="control-label"></label>
                <input asp-for="PorcentajeIva" class="form-control" readonly />
                <span asp-validation-for="PorcentajeIva" class="text-danger"></span>
            </div>
        </div>
    </fieldset>
</div>
