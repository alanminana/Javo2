@model Javo2.ViewModels.Operaciones.Proveedores.ProveedoresViewModel

<input type="hidden" asp-for="ProveedorID" />

<div class="container">
    <!-- Información Personal -->
    <fieldset class="mb-4">
        <legend>Información Personal</legend>
        <div class="row mb-3">
            <div class="col-md-6 form-group">
                <label asp-for="Nombre" class="form-label"></label>
                <input asp-for="Nombre" class="form-control" />
                <span asp-validation-for="Nombre" class="text-danger"></span>
            </div>
            <div class="col-md-6 form-group">
                <label asp-for="Apellido" class="form-label"></label>
                <input asp-for="Apellido" class="form-control" />
                <span asp-validation-for="Apellido" class="text-danger"></span>
            </div>
        </div>
    </fieldset>

    <!-- Información de Empresa -->
    <fieldset class="mb-4">
        <legend>Información de Empresa</legend>
        <div class="row mb-3">
            <div class="col-md-6 form-group">
                <label asp-for="Empresa" class="form-label"></label>
                <input asp-for="Empresa" class="form-control" />
                <span asp-validation-for="Empresa" class="text-danger"></span>
            </div>
            <div class="col-md-6 form-group">
                <label asp-for="CUIT" class="form-label"></label>
                <input asp-for="CUIT" class="form-control" />
                <span asp-validation-for="CUIT" class="text-danger"></span>
            </div>
        </div>
    </fieldset>

    <!-- Información de Contacto -->
    <fieldset class="mb-4">
        <legend>Información de Contacto</legend>
        <div class="row mb-3">
            <div class="col-md-6 form-group">
                <label asp-for="Email" class="form-label"></label>
                <input asp-for="Email" class="form-control" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>
            <div class="col-md-6 form-group">
                <label asp-for="Telefono" class="form-label"></label>
                <input asp-for="Telefono" class="form-control" />
                <span asp-validation-for="Telefono" class="text-danger"></span>
            </div>
            <div class="col-md-6 form-group">
                <label asp-for="Celular" class="form-label"></label>
                <input asp-for="Celular" class="form-control" />
                <span asp-validation-for="Celular" class="text-danger"></span>
            </div>
            <div class="col-md-6 form-group">
                <label asp-for="CondicionesPago" class="form-label"></label>
                <input asp-for="CondicionesPago" class="form-control" />
                <span asp-validation-for="CondicionesPago" class="text-danger"></span>
            </div>
        </div>
    </fieldset>

    <!-- Productos Disponibles -->
    <fieldset class="mb-4">
        <legend>Productos Disponibles</legend>
        <div class="row mb-3">
            <div class="col-md-12 form-group">
                <label for="productoAutocomplete" class="form-label">Productos Disponibles</label>
                <input type="text" id="productoAutocomplete" class="form-control" />
                <div id="selectedProductos" class="mt-2"></div>
                <span asp-validation-for="ProductosSeleccionados" class="text-danger"></span>
            </div>
        </div>
    </fieldset>
</div>